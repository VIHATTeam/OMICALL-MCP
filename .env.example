# === OMICall MCP Configuration ===

# Auth: Email/Password (recommended)
OMICALL_USERNAME=admin@company.com
OMICALL_PASSWORD=your-password
OMICALL_DOMAIN=your-company

# Auth: API Key (alternative)
# OMICALL_API_KEY=your-api-key

# Optional
# OMICALL_TENANT_ID=auto    # Auto-select if only 1 tenant
# OMICALL_ENV=prod          # prod (default) | stg
